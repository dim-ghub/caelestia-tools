#!/usr/bin/env bash
set -uo pipefail

export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

usage() {
  echo "Usage: $(basename "$0")" >&2
  echo "Screenshot a region or window and search Google by image." >&2
  echo "Click-drag to select a region, or click a window to snap to it." >&2
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    *) usage ;;
  esac
done

for cmd in grim slurp curl jq xdg-open hyprctl python3; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd not found. Install it first." >&2
    exit 1
  fi
done

tmp_img=$(mktemp /tmp/grim-search-XXXXXX.png)
trap 'rm -f "$tmp_img"' EXIT

hints=$(hyprctl clients -j 2>/dev/null | python3 -c "
import json, sys
clients = json.load(sys.stdin)
for c in clients:
    wx, wy = c['at']
    ww, wh = c['size']
    print(f'{wx},{wy} {ww}x{wh}')
")

geom=$(slurp <<< "$hints" 2>/dev/null)
[[ -z "$geom" ]] && exit 0

read -r sx sy sw sh <<< "$(echo "$geom" | awk -F'[,x ]' '{print $1, $2, $3, $4}')"
if (( sw * sh < 20 )); then
  snapped=$(echo "$hints" | while IFS= read -r rect; do
    [[ -z "$rect" ]] && continue
    read -r rx ry rw rh <<< "$(echo "$rect" | awk -F'[,x ]' '{print $1, $2, $3, $4}')"
    if (( sx >= rx && sx < rx + rw && sy >= ry && sy < ry + rh )); then
      echo "$rect"
      break
    fi
  done)
  [[ -n "$snapped" ]] && geom="$snapped"
fi

grim -g "$geom" "$tmp_img" 2>/dev/null || { echo "Screenshot failed" >&2; exit 1; }

response=$(curl -sSf --connect-timeout 5 --max-time 15 \
  -F "files[]=@$tmp_img" 'https://uguu.se/upload') || { echo "Upload failed" >&2; exit 1; }

url=$(jq -r '.files[0].url // empty' <<< "$response")
[[ -z "$url" ]] && { echo "Failed to parse upload URL" >&2; exit 1; }

xdg-open "https://lens.google.com/uploadbyurl?url=$url" &
